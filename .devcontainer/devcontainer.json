// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/universal
{
	"name": "Bluesky",
	"build": {
		"dockerfile": "./Dockerfile",
		"context": "..",
		"args": {
			"DEVCONTAINER_QGIS_VERSION": "3.34.4", // Remove to skip QGIS install (system package)
			//			"DEVCONTAINER_QGIS_DEV": "1" // Remove to skip QGIS dev libs (Qt Designer, C++ headers, pyuic5)
		}
	},
	"containerEnv": {
		"UV_PROJECT_ENVIRONMENT": "${containerWorkspaceFolder}/.venv",
		"UV_PYTHON_PREFERENCE": "managed",
		"UV_LINK_MODE": "copy", // Use copy mode for UV to avoid symlinks in the container
		// ── Required (always installed) ──
		"DEVCONTAINER_UV_VERSION": "0.8.15", // UV (Python package manager) — always installed
		"DEVCONTAINER_PYTHON_VERSION": "3.12", // Python version for venv — always installed
		// ── Opt-in (remove or comment out to skip installation) ──
		"ENABLE_GPU_AI": "0", // Set to "1" to install GPU AI/LLM stack; "0" or remove to skip
		// "DEVCONTAINER_NODE_VERSION": "22.11.0", // Remove to skip Node.js install
		"DEVCONTAINER_RUBY_VERSION": "3.2.2", // Remove to skip Ruby install
		"DEVCONTAINER_OS_STANDARDS": "0.8.4", // Remove to skip openstudio-standards gem (requires Ruby + OpenStudio)
		"DEVCONTAINER_H2K_HPXML_BRANCH": "extract-os-setup-package", // Remove to skip H2K-HPXML dependency sync
		"DEVCONTAINER_OPENSTUDIO_VERSION": "3.11.0", // Remove to skip OpenStudio/EnergyPlus install via osdep
		"DEVCONTAINER_PY_DSS_INTERFACE": "2.3.0", // Remove to skip py-dss-interface (OpenDSS) install
		// ── Host LLM access (remove to skip) ──
		"DEVCONTAINER_VLLM_PORT": "8001", // vLLM port on the host machine
		"OPENCODE_CONFIG": "${containerWorkspaceFolder}/.devcontainer/ai_assistance/opencode.container.json"
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-azuretools.vscode-docker",
				"karyfoundation.idf",
				"ms-python.python",
				"ms-python.black-formatter",
				"ms-python.isort",
				"ms-python.mypy-type-checker",
				"mechatroner.rainbow-csv",
				"janisdd.vscode-edit-csv",
				"qwtel.sqlite-viewer",
				"ms-toolsai.jupyter",
				"openai.chatgpt",
				"Anthropic.claude-code",
				"GitHub.copilot"
			],
			"settings": {
				// Copies ~/.gitconfig (and relevant includes) into the container
				"dev.containers.copyGitConfig": true,
				// Persists host credentials (e.g., Git Credential Manager) for Git in the container
				"dev.containers.persistGitCredentials": true,
				"files.associations": {
					"*.h2k": "xml",
					"*.hpxml": "xml",
					"*.sql": "sqlite"
				},
				// Re-enable extension auto activation to ensure environment loads if profile script runs too early
				"python.defaultInterpreterPath": "./.venv/bin/python",
				"python.terminal.activateEnvInCurrentTerminal": false,
				// Auto venv activation + prompt handled by /etc/profile.d/dev-env-init.sh (unified script)
				"python.terminal.activateEnvironment": false,
				"python.terminal.executeInFileDir": false,
				"python.formatting.provider": "black",
				"python.linting.enabled": true,
				"python.linting.mypyEnabled": true,
				"editor.formatOnSave": true,
				"editor.codeActionsOnSave": {
					"source.organizeImports": "explicit"
				},
				"terminal.integrated.profiles.linux": {
					"bash": {
						"path": "/bin/bash",
						"args": [
							"--login"
						]
					}
				},
				"terminal.integrated.defaultProfile.linux": "bash",
				// Hot2000 CLI Wine environment for integrated terminal
				"terminal.integrated.env.linux": {
					"WINEARCH": "win32",
					"WINEPREFIX": "/home/vscode/.wine_hot2000",
					"WINEDEBUG": "-all"
				}
			}
		}
	},
	"remoteEnv": {
		// Certificate environment variables now managed by certctl-safe
		// These were removed: NODE_EXTRA_CA_CERTS, SSL_CERT_FILE, REQUESTS_CA_BUNDLE, AWS_CA_BUNDLE, UV_NATIVE_TLS
	},
	"runArgs": [
		// Allow container to reach services on the Docker host (e.g. vLLM, Ollama)
		"--add-host=host.docker.internal:host-gateway",
		// WSLg support for GUI applications
		"--env=DISPLAY=${localEnv:DISPLAY:-:0}",
		"--env=WAYLAND_DISPLAY=${localEnv:WAYLAND_DISPLAY:-wayland-0}",
		"--env=XDG_RUNTIME_DIR=/mnt/wslg/runtime-dir",
		"--env=PULSE_SERVER=/mnt/wslg/PulseServer",
		// OpenGL and GUI framework compatibility
		"--env=LIBGL_ALWAYS_INDIRECT=1",
		"--env=QT_X11_NO_MITSHM=1",
		"--env=_JAVA_AWT_WM_NONREPARENTING=1",
		// WSL2 X11 socket mount (using correct WSL2 paths)
		"--volume=/run/desktop/mnt/host/wslg/.X11-unix:/tmp/.X11-unix",
		"--volume=/run/desktop/mnt/host/wslg:/mnt/wslg",
		// GPU support
		"--gpus=all",
		// Hot2000 CLI Wine support - required for running Windows applications under Wine
		"--env=WINEDEBUG=-all",
		"--env=WINEFSYNC=1",
		"--cap-add=SYS_PTRACE",
		"--security-opt=seccomp=unconfined",
	],
	"forwardPorts": [
		8080,
		8000,
		8001,
		3000
	],
	"portsAttributes": {
		"8080": {
			"visibility": "public",
			"protocol": "http",
			"label": "Claude Code Auth"
		},
		"8000": {
			"visibility": "public",
			"protocol": "http",
			"label": "Development Server"
		},
		"3000": {
			"visibility": "public",
			"protocol": "http",
			"label": "Web App"
		}
	},
	"mounts": [
		// Docker socket for Docker-in-Docker support enable if needed
		// Uncomment the line below to enable Docker socket access
		// Note: This is not recommended for security reasons unless you trust the container
		// and understand the implications of running Docker inside a container.
		// "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
	],
	"postCreateCommand": ".devcontainer/scripts/post-create.sh",
	"containerUser": "vscode",
	"remoteUser": "vscode"
}